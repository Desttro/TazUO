{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "enabledPlugins": {
    "csharp-lsp@claude-plugins-official": true
  },
  "env": {
    "DOTNET_NOLOGO": "true",
    "DOTNET_CLI_TELEMETRY_OPTOUT": "1",
    "DOTNET_SKIP_FIRST_TIME_EXPERIENCE": "1",
    "NUGET_XMLDOC_MODE": "skip"
  },
  "respectGitignore": true,
  "claudeMdExcludes": [
    "external/**",
    "bin/**",
    "obj/**"
  ],
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(dotnet build)",
      "Bash(dotnet build *)",
      "Bash(dotnet restore)",
      "Bash(dotnet restore *)",
      "Bash(dotnet test)",
      "Bash(dotnet test *)",
      "Bash(dotnet format *)",
      "Bash(dotnet --info)",
      "Bash(dotnet --list-sdks)",
      "Bash(dotnet nuget list source)",
      "Bash(./format.sh)",
      "Bash(./tools/generate-docs.sh)",
      "Bash(git status)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git restore *)",
      "Bash(git stash)",
      "Bash(git stash *)",
      "Bash(git fetch)",
      "Bash(git fetch *)",
      "Bash(git pull)",
      "Bash(git pull *)",
      "Bash(git submodule *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr checks *)",
      "Bash(gh issue view *)",
      "Bash(gh issue list *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(jq *)",
      "Bash(tree *)",
      "Bash(file *)",
      "Bash(chmod +x *)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git rebase *)",
      "Bash(git merge *)",
      "Bash(git cherry-pick *)",
      "Bash(git tag *)",
      "Bash(gh pr create *)",
      "Bash(gh pr merge *)",
      "Bash(gh issue create *)",
      "Bash(dotnet add *)",
      "Bash(dotnet remove *)",
      "Bash(dotnet nuget add *)",
      "Edit(.github/**)",
      "Edit(**/*.csproj)",
      "Edit(**/*.sln)",
      "Edit(Directory.Build.props)",
      "Edit(global.json)",
      "Edit(.editorconfig)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(sudo *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git push --no-verify *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd*)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(./secrets/**)",
      "Read(**/credentials.json)",
      "Read(**/appsettings.*.json)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/format-cs.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash(git push*)",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-push-build.sh",
            "timeout": 360
          }
        ]
      }
    ]
  }
}
